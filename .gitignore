# --- Secrets (실제 값이 들어가는 파일, *.example.yaml만 커밋) ---
# secret.yaml: 로컬(docker-desktop) 테스트용 수동 경로. 운영 클러스터는 AWS Secrets Manager +
# Secrets Store CSI Driver(CICD/secret-provider-class.yaml, 실제 값 없음, 커밋 대상)로 doro-secret을
# 자동 생성하므로 이 파일 자체를 만들 필요가 없다.
secret.yaml
CICD/secret.yaml
*.secret.yaml
*-secret.yaml
!*secret.example.yaml

# --- 환경 변수 / 자격 증명 ---
.env
.env.*
!.env.example
*_accessKeys.csv
*.pem
*.key
*.crt
*.p12

# --- kubeconfig ---
kubeconfig
*.kubeconfig

# --- Terraform ---
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl

# --- Helm ---
charts/*.tgz

# --- kustomize 빌드 산출물 ---
*-rendered.yaml
build/

# --- OS / 편집기 ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- 로그 ---
*.log
